# proxy.env — copy to ~/.roxabi/llmcli/env/proxy.env (chmod 600)
# Provider keys (required for cloud models)
LLMCLI_API_KEY=
FIREWORKS_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NVIDIA_API_KEY=

# ── OpenTelemetry v2 → factory-otel-collector → Langfuse (ADR-092) ───────────
# Enable on factory-hub hosts where factory-otel-collector runs on roxabi.network.
# OMP + any LiteLLM consumer traces land here (secondary to Claude Code clipool).
# LITELLM_OTEL_V2=true
# OTEL_EXPORTER=otlp_grpc
# OTEL_ENDPOINT=http://factory-otel-collector:4317
# OTEL_SERVICE_NAME=llmcli-proxy
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=no_content