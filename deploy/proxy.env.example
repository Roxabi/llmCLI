# proxy.env — copy to ~/.roxabi/llmcli/env/proxy.env (chmod 600)
# Provider keys (required for cloud models)
LLMCLI_API_KEY=
FIREWORKS_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NVIDIA_API_KEY=

# ── OpenTelemetry v2 → factory-otel-collector → Langfuse ─────────────────────
# LiteLLM >=1.89: LITELLM_OTEL_V2 env integration (no callbacks: ["otel"] needed).
# LITELLM_OTEL_V2=true
# OTEL_EXPORTER=otlp_grpc
# OTEL_ENDPOINT=http://factory-otel-collector:4317
# OTEL_SERVICE_NAME=llmcli-proxy
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=no_content
#
# Legacy v1 (LiteLLM <1.89 or explicit opt-in): LLMCLI_OTEL_ENABLED=1 auto-injects
# callbacks: ["otel"] — do not combine with LITELLM_OTEL_V2.